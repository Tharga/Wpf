<Window x:Class="Tharga.Wpf.Sample.ChildWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Child Window" Height="200" Width="350">
    <StackPanel Margin="20">
        <CheckBox x:Name="BlockClosingCheckBox" Content="Block closing" FontSize="14" Margin="0,0,0,10" />
        <TextBlock Text="This window remembers its position." FontSize="12" Foreground="Gray" />
        <TextBlock Text="When 'Block closing' is checked, soft close of the main window will be prevented." FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,5,0,0" />
    </StackPanel>
</Window>
